# --- TesisAIOps .gitignore ---

# Entornos virtuales
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Secretos y configuración local (ADR-008: nunca versionar .env)
.env
config/.env

# Corpus REAL de logs (Fase 3.5): NO versionar — datos sensibles (IPs/hosts
# internos, endpoints reales) y voluminosos. Se conservan SOLO los samples
# sintéticos anonimizados usados por los tests/demo.
data/logs/*
!data/logs/.gitkeep
!data/logs/haproxy_sample.log
!data/logs/iis_sample.log

# Salida del parser (datos derivados, regenerables)
data/processed/*
!data/processed/.gitkeep

# Índice vectorial de Chroma (datos derivados, regenerables) - Fase 2D
data/index/

# IDE / editor
.vscode/
.idea/
*.swp

# Sistema operativo
Thumbs.db
.DS_Store
